{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sir.local/schemas/sir_contract_v1.schema.json",
  "title": "SIR Contract v1",
  "type": "object",
  "required": [
    "version",
    "packet_id",
    "source_lang",
    "target_lang",
    "intent",
    "text",
    "concepts",
    "relations",
    "constraints",
    "protected_spans",
    "uncertainty",
    "stats"
  ],
  "properties": {
    "version": {"const": "sir.v1"},
    "packet_id": {"type": "string", "minLength": 1},
    "source_lang": {"type": "string", "minLength": 2},
    "target_lang": {"type": "string", "minLength": 2},
    "intent": {
      "type": "object",
      "required": ["label", "confidence", "signals"],
      "properties": {
        "label": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "signals": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "text": {
      "type": "object",
      "required": ["scrubbed"],
      "properties": {"scrubbed": {"type": "string"}},
      "additionalProperties": false
    },
    "concepts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "role", "score", "source", "surface", "definition_en", "segment"],
        "properties": {
          "id": {"type": "string"},
          "role": {"type": "string"},
          "score": {"type": "number"},
          "source": {"type": "string"},
          "surface": {
            "type": "object",
            "properties": {
              "en": {"type": "string"},
              "ru": {"type": "string"}
            },
            "additionalProperties": {"type": "string"}
          },
          "definition_en": {"type": "string"},
          "segment": {"type": "integer"}
        },
        "additionalProperties": false
      }
    },
    "relations": {"type": "array", "items": {"type": "object"}},
    "constraints": {"type": "array", "items": {"type": "object"}},
    "protected_spans": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["placeholder", "kind", "surface_hash"],
        "properties": {
          "placeholder": {"type": "string"},
          "kind": {"type": "string"},
          "surface_hash": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "uncertainty": {"type": "array", "items": {"type": "object"}},
    "stats": {"type": "object"},
    "kernel": {"type": "object"}
  },
  "additionalProperties": false
}
