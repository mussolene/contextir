{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/mussolene/contextir/main/contextir/schemas/contextir_contract_v2.schema.json",
  "title": "ContextIR Contract v2",
  "type": "object",
  "required": [
    "version",
    "id",
    "language",
    "mode",
    "intent",
    "entities",
    "events",
    "constraints",
    "concepts",
    "privacy",
    "source",
    "uncertainty",
    "stats"
  ],
  "properties": {
    "version": {"const": "contextir.v2"},
    "id": {"type": "string", "minLength": 1},
    "language": {
      "type": "object",
      "required": ["source", "target"],
      "properties": {
        "source": {"type": "string", "minLength": 2},
        "target": {"type": "string", "minLength": 2}
      },
      "additionalProperties": false
    },
    "mode": {"enum": ["raw", "hybrid", "semantic"]},
    "intent": {
      "type": "object",
      "required": ["label", "confidence"],
      "properties": {
        "label": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "value"],
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string"},
          "value": {"type": "string"},
          "source_ref": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "predicate", "arguments", "polarity", "modality", "condition", "source_ref", "confidence", "count"],
        "properties": {
          "id": {"type": "string"},
          "predicate": {"type": "string"},
          "arguments": {"type": "array", "items": {"type": "string"}},
          "polarity": {"enum": ["positive", "negative"]},
          "modality": {"enum": ["none", "requirement", "prohibition"]},
          "condition": {"type": "string"},
          "source_ref": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "count": {"type": "integer", "minimum": 1}
        },
        "additionalProperties": false
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "value"],
        "properties": {
          "type": {"type": "string"},
          "value": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "concepts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "score"],
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string"},
          "score": {"type": "number"}
        },
        "additionalProperties": false
      }
    },
    "privacy": {
      "type": "object",
      "required": ["protected"],
      "properties": {
        "protected": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["placeholder", "kind"],
            "properties": {
              "placeholder": {"type": "string"},
              "kind": {"type": "string"}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": ["refs", "included"],
      "properties": {
        "refs": {"type": "array", "items": {"type": "string"}},
        "included": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["ref", "text"],
            "properties": {
              "ref": {"type": "string"},
              "text": {"type": "string"}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "uncertainty": {
      "type": "object",
      "required": ["semantic_confidence", "requires_source"],
      "properties": {
        "semantic_confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "requires_source": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "stats": {
      "type": "object",
      "required": ["source_chars", "contract_chars", "prompt_chars", "prompt_ratio", "source_segments", "included_segments", "latency_ms"],
      "properties": {
        "source_chars": {"type": "integer", "minimum": 1},
        "contract_chars": {"type": "integer", "minimum": 1},
        "prompt_chars": {"type": "integer", "minimum": 1},
        "prompt_ratio": {"type": "number", "minimum": 0},
        "source_segments": {"type": "integer", "minimum": 1},
        "included_segments": {"type": "integer", "minimum": 0},
        "latency_ms": {"type": "number", "minimum": 0}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
